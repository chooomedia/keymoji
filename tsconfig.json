{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    
    /* Emit */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    // NOTE: verbatimModuleSyntax entfernt - verursacht 500-Fehler in Vite
    // Stattdessen: Explizite type-Imports in Store-Dateien verwenden
    
    /* Type Checking */
    // PERFORMANCE: Balance zwischen Type Safety und Build-Performance
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    // PERFORMANCE: Disable für bessere Build-Performance (kann später aktiviert werden)
    "noUnusedLocals": false, // false für bessere Performance
    "noUnusedParameters": false, // false für bessere Performance
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false, // false für bessere Performance
    "noImplicitOverride": true,
    
    /* Completeness */
    "skipLibCheck": true,
    
    /* Svelte-specific */
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.svelte",
    "webpack/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}

