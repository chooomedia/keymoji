{
    "name": "keymoji",
    "version": "0.7.7",
    "description": "Secure emoji password generator with AI Story Mode - Security & Configuration",
    "private": true,
    "license": "MIT",
    "author": {
        "name": "Christopher Matt",
        "url": "https://keymoji.wtf"
    },
    "homepage": "https://keymoji.wtf",
    "repository": {
        "type": "git",
        "url": "https://github.com/chooomedia/keymoji"
    },
    "bugs": {
        "url": "https://github.com/chooomedia/keymoji/issues"
    },
    "scripts": {
        "dev": "webpack serve --config webpack/start.js",
        "prebuild": "node scripts/update-timestamp.js && node scripts/generate-sitemap.js",
        "build": "webpack --config webpack/build.js && node scripts/generate-static-routes.js && node scripts/optimize-build.js",
        "postbuild": "tsx scripts/prerender-meta.js",
        "check:images": "node scripts/check-social-images.js",
        "setup:fonts": "node scripts/setup-fonts.js",
        "validate:schema": "node scripts/validate-structured-data.js",
        "generate:token": "node scripts/generate-n8n-token.js",
        "generate:token:dev": "node scripts/generate-n8n-token.js --env dev",
        "generate:token:prod": "node scripts/generate-n8n-token.js --env prod",
        "check:apertus-token": "node scripts/check-apertus-token.js",
        "setup:apertus": "bash scripts/setup-apertus-token.sh",
        "version:bump": "node scripts/bump-version.js",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.3",
        "@babel/core": "^7.28.5",
        "@babel/preset-env": "^7.28.5",
        "@types/node": "^22.19.1",
        "autoprefixer": "^10.4.22",
        "babel-loader": "^8.2.2",
        "clean-webpack-plugin": "^3.0.0",
        "copy-webpack-plugin": "^6.4.1",
        "css-loader": "^5.2.7",
        "css-minimizer-webpack-plugin": "^3.4.1",
        "cssnano": "^5.1.15",
        "file-loader": "^6.2.0",
        "html-entities": "^2.6.0",
        "html-webpack-plugin": "^5.6.4",
        "mini-css-extract-plugin": "^1.6.2",
        "postcss": "^8.4.47",
        "postcss-loader": "^5.3.0",
        "style-loader": "^2.0.0",
        "svelte-loader": "^3.2.4",
        "svelte-preprocess": "^5.1.4",
        "tailwindcss": "^3.4.18",
        "terser-webpack-plugin": "^5.3.10",
        "ts-loader": "^9.5.4",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "webpack": "^5.102.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.2.2",
        "webpack-merge": "^5.7.3"
    },
    "dependencies": {
        "dotenv": "^16.3.1",
        "svelte": "^5.43.7",
        "web-vitals": "^3.5.0"
    },
    "babel": {
        "presets": [
            "@babel/preset-env"
        ]
    },
    "browserslist": [
        "last 3 chrome version",
        "last 3 firefox version",
        "last 3 safari version",
        "last 3 ios_saf version"
    ],
    "prettier": {
        "printWidth": 80,
        "tabWidth": 4,
        "useTabs": false,
        "semi": true,
        "singleQuote": true,
        "trailingComma": "none",
        "bracketSpacing": true,
        "jsxBracketSameLine": false,
        "arrowParens": "avoid"
    }
}
