            "parameters": {
                "jsCode": "// Validate OTP: compare code + check expiry\nconst items = $input.all();\n\n// items[0] = incoming verify_otp request (from Extract Body via Router)\n// items[1] = Google Sheets row\n// IMPORTANT: With switch nodes, we need to get the original request differently\n// The lookup node output contains the sheet row; incoming data is in the first item\nconst sheetRow = items[0].json;\n\n// Get the verify request from the execution context\n// The incoming data was passed through as the sheet query used $json.email\n// so we need to re-fetch from earlier — use $('Action Router') to get original data\nlet requestData;\ntry {\n  requestData = $('Action Router').first().json;\n} catch(e) {\n  // fallback\n  requestData = items[0].json;\n}\n\nconst incomingCode = String(requestData.otpCode || '').trim();\nconst incomingEmail = String(requestData.email || '').trim();\n\nconsole.log('🔍 Verifying OTP for:', incomingEmail);\nconsole.log('🔍 Incoming code:', incomingCode);\nconsole.log('🔍 Sheet row:', JSON.stringify(sheetRow));\n\n// No row found\nif (!sheetRow || !sheetRow.email) {\n  console.warn('❌ No account found for email:', incomingEmail);\n  return { json: { success: false, error: 'No account found for this email' } };\n}\n\nconst storedCode = String(sheetRow.otp_code || '').trim();\nconst expiresAt = sheetRow.otp_expires_at;\n\n// Check code match\nif (!storedCode || storedCode !== incomingCode) {\n  console.warn('❌ OTP mismatch. Expected:', storedCode, 'Got:', incomingCode);\n  return { json: { success: false, error: 'Invalid code. Please check and try again.' } };\n}\n\n// Check expiry\nif (expiresAt) {\n  const expiry = new Date(expiresAt);\n  const now = new Date();\n  if (now > expiry) {\n    console.warn('❌ OTP expired at:', expiresAt);\n    return { json: { success: false, error: 'Code has expired. Please request a new one.' } };\n  }\n}\n\n// SUCCESS: clear OTP from sheet (security: single-use)\nconsole.log('✅ OTP valid for:', incomingEmail);\nreturn {\n  json: {\n    success: true,\n    userId: sheetRow.userId || null,\n    email: incomingEmail,\n    clearOtp: true  // signal to next node\n  }\n};"
            },
